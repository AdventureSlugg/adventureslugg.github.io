<script is:inline>
	let started = false;
	let score = 0;
	let trashCount = 0;

	function startGame() {
		resetScore();
		started = true;

		// Hide start button
		const startButton = document.getElementById('start-button');
		startButton.classList.toggle('hidden');

		const container = document.querySelector(".game-container");

		// Spawn trash every ~500ms
		const spawnInterval = setInterval(() => {
			if (trashCount > 59) return;

			if (!started) return;

			const trash = document.createElement("div");
			trash.className = "trash";

			// Trash style
			trash.style.top = "0px";
			trash.style.backgroundColor = 'lightgreen'
			trash.style.height = '40px';
			trash.style.width = '40px';
			trash.style.borderRadius = '6vh';
			trash.style.position = 'absolute';

			// Set the x position of the trash object
			trash.style.left = `${Math.random() * (container.getBoundingClientRect().width - 50)}px`;

			// Add the trash to the top 
			container.appendChild(trash);
			trashCount += 1;

			fall(trash);
		}, 500);

		// Game will last for 30 seconds
		setTimeout(() => {
			started = false;
			startButton.classList.toggle('hidden');

			// End the trash spawn
			clearInterval(spawnInterval);
		}, 32500); // Additional 2.5 seconds for last trash to fall
	}

	function incrementScore () {
		const scoreElement = document.getElementById('score');
		score++;
		scoreElement.innerText = score.toString();
	}

	function resetScore () {
		score = 0;
		trashCount = 0;
	}

	function fall(trash) {
		const speed = 2 + Math.random() * 3;
		const container = trash.parentElement;

		function step() {
			if (!started) {
				trash.remove();
				return;
			}

			const currentTop = parseFloat(trash.style.top);
			trash.style.top = `${currentTop + speed}px`;

			checkCollision(trash);

			// Remove if off screen
			if (container && currentTop > container.getBoundingClientRect().height) {
				trash.remove();
				return;
			}
			requestAnimationFrame(step);
		}

		requestAnimationFrame(step);
	}

	function checkCollision(trash) {
		const bin = document.getElementById("trash-bin");
		if (!bin) return;

		const trashRect = trash.getBoundingClientRect();
		const binRect = bin.getBoundingClientRect();

		const isColliding = trashRect.bottom >= binRect.top && trashRect.left < binRect.right && trashRect.right > binRect.left;

		// On collide, increment score and remove trash from the view
		if (isColliding) {
			trash.remove();
			incrementScore();
		}
	}
</script>

<div class="trash-content">
	<div class="game-container" id="game-container">
		<p>Catch the trash as it falls!</p>
		<p class="score">
			<span>
				Score: 
			</span>
			<span id="score">
				0
			</span>
		</p>
		<button id="start-button" onclick="startGame()">Start</button>
		<img id="trash-bin" src="/icons/trash-icon.webp" alt="trash-bin" draggable="false">
	</div>
	
</div>

<script is:inline>
	document.addEventListener("DOMContentLoaded", () => {
		const gameContainer = document.getElementById("game-container");
		const binElement = document.getElementById("trash-bin");
		const desktopPointerQuery = window.matchMedia("(min-width: 1001px)");
		let activePointerId = null;
		let dragging = false;

		if (!gameContainer || !binElement) return;

		function clampBinLeft(left) {
			const containerWidth = gameContainer.getBoundingClientRect().width;
			const binWidth = binElement.getBoundingClientRect().width;
			const maxLeft = Math.max(containerWidth - binWidth, 0);

			return Math.min(Math.max(left, 0), maxLeft);
		}

		function setBinLeft(left) {
			binElement.style.left = `${clampBinLeft(left)}px`;
		}

		function moveBinToPointer(clientX) {
			const containerLeft = gameContainer.getBoundingClientRect().left;
			const binHalfWidth = binElement.getBoundingClientRect().width / 2;

			setBinLeft(clientX - containerLeft - binHalfWidth);
		}

		function centerBin() {
			const containerWidth = gameContainer.getBoundingClientRect().width;
			const binWidth = binElement.getBoundingClientRect().width;

			setBinLeft((containerWidth - binWidth) / 2);
		}

		function isDesktopPointerMode() {
			return desktopPointerQuery.matches;
		}

		function followPointer(e) {
			if (!isDesktopPointerMode() || !e.isPrimary) return;

			moveBinToPointer(e.clientX);
		}

		function releaseActivePointerCapture() {
			if (activePointerId === null) return;

			if (binElement.hasPointerCapture(activePointerId)) {
				binElement.releasePointerCapture(activePointerId);
			}
		}

		function startDrag(e) {
			if (isDesktopPointerMode() || !e.isPrimary) return;

			dragging = true;
			activePointerId = e.pointerId;
			binElement.setPointerCapture(activePointerId);
			moveBinToPointer(e.clientX);
			e.preventDefault();
		}

		function drag(e) {
			if (isDesktopPointerMode() || !dragging || e.pointerId !== activePointerId) return;

			moveBinToPointer(e.clientX);
			e.preventDefault();
		}

		function stopDrag(e) {
			if (!dragging || e.pointerId !== activePointerId) return;

			releaseActivePointerCapture();
			dragging = false;
			activePointerId = null;
		}

		function syncPointerMode() {
			releaseActivePointerCapture();
			dragging = false;
			activePointerId = null;

			const currentLeft = parseFloat(binElement.style.left);

			if (Number.isNaN(currentLeft)) {
				centerBin();
				return;
			}

			setBinLeft(currentLeft);
		}

		document.addEventListener("pointermove", followPointer);
		binElement.addEventListener("pointerdown", startDrag);
		binElement.addEventListener("pointermove", drag);
		binElement.addEventListener("pointerup", stopDrag);
		binElement.addEventListener("pointercancel", stopDrag);
		binElement.addEventListener("lostpointercapture", stopDrag);
		desktopPointerQuery.addEventListener("change", syncPointerMode);
		window.addEventListener("resize", syncPointerMode);

		centerBin();
	});
</script>

<style>

@media (min-width: 1001px) {
	#trash-bin {
		position: absolute;
		bottom: 0;
		cursor: default;
	}
}
@media (max-width: 1000px) {
	#trash-bin {
		position: absolute;
		bottom: 12vh;
		cursor: grab;
	}
}
.hidden {
	display: none;
}
.trash-content {
	height: 100%;
	width: 100%;
	background-color: rgba(1,1,1,.85);
	color: white;
	text-align: center;
	font-size: 2vh;
}

.game-container {
	display: flex;
	flex-direction: column;
	height: 100%;
	overflow: hidden;
	position: relative;
	touch-action: none;
	user-select: none;
	width: 100%;
}

.score {
	background-color: aquamarine;
	width: fit-content;
	position: absolute;
	padding: 1vh 2vw;
	border-radius: 1vh;
	color: rgb(75, 75, 75);
	left: 1vw;
	border: solid .5vh rgb(199, 255, 236);
	opacity: .8;
}

#start-button {
	width: fit-content;
	padding: 1vh 2vw;
	position: absolute;
	background-color: rgb(0, 149, 255);
	border: none;
	border-radius: 1vh;
	color: white;
	right: 3vw;
	top: 5vh;
	font-size: 2vh;
}

#start-button:hover {
	scale: 1.4;
}

#trash-bin {
	width: 10vh;
	height: 10vh;
	left: calc(50% - 5vh);
	touch-action: none;
	-webkit-user-drag: none;
	z-index: 1;
}

#trash-bin:active {
	cursor: grabbing;
}
</style>
