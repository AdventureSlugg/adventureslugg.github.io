---
import ApplicationContainer from "../components/ApplicationContainer/applicationContainer.astro";
import Toolbar from "../components/ToolBar/toolbar.astro";
---

<div class="desktop">
	<div class="menu-bar">

	</div>
	<div class="main-content">
		<ApplicationContainer id="message-notice">
			<div class="text content" slot="content">
				<h1>
					UPDATE:
				</h1>
				<p>
					Thanks for stopping by! My portfolio is currently under reconstruction.
				</p>

				<p>
					Updates will continue gradually over the next couple of weeks. 
				</p>

				<p>
					Hope to see you again soon!
				</p>
			</div>
		</ApplicationContainer>
	</div>
	<div class="tool-bar">
		<Toolbar></Toolbar>
	</div>
</div>

<style>
	.desktop {
		background-color: rgb(0, 0, 0);
		background-image: url(/public/background/cat-background.png);
		background-repeat: no-repeat;
		background-size: cover;
		min-width: 100vw;
		min-height: 100vh;
	}

	.menu-bar {
		background-color: black;
		min-width: 100vw;
		min-height: 3vh;
	}

	.main-content {
		height: 97vh;
	}

	.content {
		background-color: var(--dark-bg);
		opacity: .8;
		flex: 1;
		overflow-y: scroll;
	}

	.text {
		color: white;
		padding: 1vw;
	}

	@media (min-width: 585px) {
		.tool-bar {
			position: absolute;
			width: 60vw;
			height: 11vh;
			border-radius: 1vw;
			background-color: var(--dark-bg);
			opacity: 80%;
			bottom: 0;
			margin: 1vh 20vw;
			border: solid .1vw var(--dark-stroke);
			box-shadow: var(--box-shadow);
			min-width: 60vh;
		}
	}

	@media (max-width: 584px) {
		.tool-bar {
			position: absolute;
			width: 70vw;
			height: 6vh;
			border-radius: 1vw;
			background-color: var(--dark-bg);
			opacity: 80%;
			bottom: 0;
			margin: 4vh 15vw;
			border: solid .1vw var(--dark-stroke);
			box-shadow: var(--box-shadow);
			min-width: 30vh;
		}
	}
</style>