<script is:inline>
	let started = false;
	let score = 0;

	function startGame() {
		resetScore();
		started = true;

		// Hide start button
		const startButton = document.getElementById('start-button');
		startButton.classList.toggle('hidden');

		const container = document.querySelector(".game-container");

		// Spawn trash every ~500ms
		const spawnInterval = setInterval(() => {
			if (!started) return;

			const trash = document.createElement("div");
			trash.className = "trash";

			// Trash style
			trash.style.top = "0px";
			trash.style.backgroundColor = 'lightgreen'
			trash.style.height = '40px';
			trash.style.width = '40px';
			trash.style.borderRadius = '6vh';
			trash.style.position = 'absolute';

			// Set the x position of the trash object
			trash.style.left = `${Math.random() * (container.getBoundingClientRect().width - 50)}px`;

			// Add the trash to the top 
			container.appendChild(trash);

			fall(trash);
		}, 500);

		// Game will last for 30 seconds
		setTimeout(() => {
			started = false;
			startButton.classList.toggle('hidden');

			// End the trash spawn
			clearInterval(spawnInterval);
		}, 30000);
	}

	function incrementScore () {
		const scoreElement = document.getElementById('score');
		score++;
		scoreElement.innerText = score.toString();
	}

	function resetScore () {
		score = 0;
	}

	function fall(trash) {
		const speed = 2 + Math.random() * 3;

		function step() {
			if (!started) {
				trash.remove();
				return;
			}

			const currentTop = parseFloat(trash.style.top);
			trash.style.top = `${currentTop + speed}px`;

			checkCollision(trash);

			// Remove if off screen
			if (currentTop > window.innerHeight) {
				trash.remove();
				return;
			}
			requestAnimationFrame(step);
		}

		requestAnimationFrame(step);
	}

	function checkCollision(trash) {
		const bin = document.getElementById("trash-bin");
		if (!bin) return;

		const trashRect = trash.getBoundingClientRect();
		const binRect = bin.getBoundingClientRect();

		const isColliding = trashRect.bottom >= binRect.top && trashRect.left < binRect.right && trashRect.right > binRect.left;

		// On collide, increment score and remove trash from the view
		if (isColliding) {
			trash.remove();
			incrementScore();
		}
	}
</script>

<div class="trash-content">
	<div class="game-container" id="game-container">
		<p>Catch the trash as it falls!</p>
		<p class="score">
			<span>
				Score: 
			</span>
			<span id="score">
				0
			</span>
		</p>
		<button id="start-button" onclick="startGame()">Start</button>
		<img id="trash-bin" src="/icons/trash-icon.png" alt="trash-bin">
	</div>
	
</div>

<script is:inline>
	document.addEventListener("DOMContentLoaded", () => {
		const binElement = document.getElementById("trash-bin");

		function translateGameObject(e) {
			if (!binElement) return;

			const gameContainerLeft = document.getElementById('game-container').getBoundingClientRect().left;
			const binHalfWidth = binElement.getBoundingClientRect().width / 2;
			const leftOffset = gameContainerLeft + binHalfWidth;

			binElement.style.left = `${(e.clientX - leftOffset)}px`;
		}

		document.addEventListener("pointermove", translateGameObject);
	});
</script>

