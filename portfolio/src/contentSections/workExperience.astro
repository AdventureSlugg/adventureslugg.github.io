---
import LeftBrowseLayout from "../components/LeftBrowseLayout/leftBrowseLayout.astro";
import type { IBrowseBarProps } from "../components/OptionBrowseBar/IOptionBrowseBar";
import OptionBrowseBar from "../components/OptionBrowseBar/optionBrowseBar.astro";

const browser: IBrowseBarProps = {
	browserId: "work-experience-browser",
	title: "Work Experience",
	filters: ['Migration', 'Automation', 'Documentation'],
	searchObjects: [
		{
			id: "honeywell",
			title: "Honeywell",
			categories: [],
			desc: 'Fullstack Software Engineer (01/2024 - 01/2025)'
		},
		{
			id: "poseidon1",
			title: "Poseidon Systems",
			categories: [],
			desc: 'Fullstack Web Engineer (08/2023 - 01/2024)'
		},
		{
			id: "carrier",
			title: "Carrier",
			categories: [],
			desc: 'Fullstack Software Engineer (01/2023 - 08/2023)'
		},
		{
			id: "poseidon0",
			title: "Poseidon Systems",
			categories: [],
			desc: 'Fullstack Web Engineer (08/2022 - 01/2023)'
		},
		{
			id: "rit",
			title: "Rochester Institute of Technology",
			categories: [],
			desc: 'Supplemental Instruction Leader (08/2021 - 08/2022)'
		},
	]
}
---

<div class="work-experience">
	<LeftBrowseLayout>
		<div slot="left-bar" class="full-height">
			<OptionBrowseBar {...browser}/>
		</div>
		<div slot="main-content">
			{
				browser.searchObjects.map(o => {
					return (
						<div id={o.id + '-section'}>Currently working on this</div>
					)
				})
			}
		</div>
	</LeftBrowseLayout>
</div>

<style>
	.work-experience {
		height: 100%;
		width: 100%;
		background-color: rgba(25, 85, 82, 0.8);
	}

	.full-height {
		height: 100%;
	}
</style>