}

.project-info {
	flex: 1;
	overflow-y: scroll;
}

.projects-selection {
	margin-top: 1vh;
}

.project-card {
	margin: 1vh 0 0 .5vw;
	background: rgb(38, 54, 59);
	color: white;
	font-size: 12px;
	padding: 1vh 1vw;
	border-radius: .5vh;
	border: .1vh solid var(--dark-stroke);
}

.last {
	margin-bottom: 6vh;
}

.project-card:hover {
	scale: 1.1;
}

.categories {
	display: flex;
	overflow-x: scroll;
	scrollbar-width: thin;
}

.project-info {
	color: white;
	padding: 2vh 2vw
}

.selected {
	border-color: rgb(255, 255, 255);
	background-color: rgba(96, 213, 255, 0.8);
	box-shadow: 0vh 0vh 1vh rgba(169, 228, 255, 0.8);
}

</style>