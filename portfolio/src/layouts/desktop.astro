---
import ApplicationContainer from "../components/ApplicationContainer/applicationContainer.astro";
import Toolbar from "../components/ToolBar/toolbar.astro";
import AboutMe from "../contentSections/aboutMe.astro";
import Projects from "../contentSections/projects.astro";
import WorkExperience from "../contentSections/workExperience.astro";
import ContactMe from "../contentSections/contactMe.astro";
import TrashGame from "../contentSections/trashGame.astro";
import type { IToolBarOption } from "../components/ToolBar/ToolBarOption/IToolBarOption";
import ToolBarOption from "../components/ToolBar/ToolBarOption/toolBarOption.astro";

interface IContentSection {
	/** Used to reference the related components (ex: id-application-container and id-menu-option) */
	id: string,

	/** The title to be displayed on the icon hover and the Application Container interface */
	title: string,

	/** If the content section should be included in the tool bar at the bottom the screen, include the icon image url */
	icon?: string,

	/** A reference to another Astro component to be rendered in the application container interface */
	innerContent: (_props: Record<string, any>) => any;

	/** Determines whether or not the application should be "open" by default. */
	initialDisplay?: boolean
}

const sections: IContentSection[] = [
	{
		id: 'projects',
		title: 'Projects',
		icon: '/icons/terminal-icon.png',
		innerContent: Projects,
		initialDisplay: true
	},
	{
		id: 'work-experience',
		title: 'Work Experience',
		icon: '/icons/calendar-icon.png',
		innerContent: WorkExperience,
		// initialDisplay: true
	},
	{
		id: 'about-me',
		title: 'About Me',
		icon: '/icons/books-icon.png',
		innerContent: AboutMe,
		// initialDisplay: true
	},
	{
		id: 'contact-me',
		title: 'Contact Me',
		icon: '/icons/contact-book-icon.png',
		innerContent: ContactMe,
		// initialDisplay: true
	}
]

const noIcon = '/icons/contact-book-icon.png';

---
<script is:inline>
	let topZ = 0;
</script>

<div class="desktop">
	<div class="menu-bar">

	</div>

	<div class="main-content">
		{
			sections.map(section => {
				const InnerContent = section.innerContent;

				return <ApplicationContainer id={section.id + '-application-container'} open={section.initialDisplay}>
					<div slot="content" class="full-height full-width">
						<InnerContent id={section.id + '-content'} title={section.title}></InnerContent>
					</div>
				</ApplicationContainer>
			})
		}
		<ApplicationContainer id="trash-game-application-container">
			<div slot="content" class="full-height full-width">
				<TrashGame></TrashGame>
			</div>
		</ApplicationContainer>
	</div>

	<div class="mobile-content">
		<div class="top-banner">
			<h1>
				Welcome to Zoe's Playground!
			</h1>

			<p>Update:</p>

			<p>
				Currently working on Mobile Interactions. Please check back again soon!
			</p>
		</div>

		<div class="app-icons">
			{
				() => {
					return sections.map(section => {
						return (
							<div class="mobile-icon">
								<ToolBarOption 
									id={section.id + '-menu-option'}
									title={section.title}
									url={section.icon ? section.icon : noIcon}
									applicationId={section.id + '-application-container'}
									iconSize="large"
								/>	
								<p class="mobile-icon-text">
									{section.title}
								</p>
							</div>
							
						)		
					})
				}
			}
		</div>
	</div>

	<div class="tool-bar">
		{
			() => {
				const toolBarOptions: IToolBarOption[] = [];

				sections.map(section => {
					toolBarOptions.push({
						id: section.id + '-menu-option',
						title: section.title,
						url: section.icon ? section.icon : noIcon,
						applicationId: section.id + '-application-container',
						iconSize: 'small'
					});				
				})

				toolBarOptions.push({
					title: 'Trash',
					url: '/icons/trash-icon.png',
					id: 'trash-game',
					applicationId: 'trash-game-application-container',
					iconSize: 'small',
					leftOption: true
				})

				return <Toolbar menuOptions={toolBarOptions}/>
			}
		}
	</div>
</div>

<style>
	.mobile-icon {
		margin-bottom: 3vh;
	}

	.mobile-icon-text {
		margin: auto;
		color: white;
		width: fit-content;
		text-align: center;
	}
	.app-icons {
		flex: 1;
		padding: 0vh 8vw;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
	}

	.top-banner {
		background-color: rgba(24, 24, 24, 0.9);
		height: 25%;
		margin: 3vh 8vw;
		min-width: calc(100% - 26vw);
		border-radius: 3vw;
		padding: 2vh 5vw;
		color: white;
		text-align: center;
	}

	.desktop {
		background-color: rgb(0, 0, 0);
		background-image: url(/public/background/cat-background.webp);
		background-repeat: no-repeat;
		background-size: cover;
		min-width: 100vw;
		min-height: 100vh;
	}

	.menu-bar {
		background-color: black;
		min-width: 100vw;
		min-height: 3vh;
	}

	h1 {
		font-size: 3vh;
	}

	p {
		font-size: 2vh;
	}

	.content {
		background-color: rgba(0, 0, 0, .9);
		opacity: 1;
		flex: 1;
		overflow-y: scroll;
	}

	.text {
		color: white;
		padding: 1vw;
	}

	.tool-bar {
		background-color: rgba(54, 54, 54, .8);
	}

	@media (min-width: 1001px) {
		.desktop-content {
			display: inherit;
		}

		.mobile-content {
			display: none;
		}

		.tool-bar {
			position: absolute;
			z-index: 999 !important;
			width: 60vw;
			height: 11vh;
			border-radius: 1vw;
			bottom: 0;
			margin: 1vh 20vw;
			border: solid .1vw var(--dark-stroke);
			box-shadow: var(--box-shadow);
			min-width: 60vh;
		}
		.mobile-update {
			display: none;
		}
	}

	@media (max-width: 1000px) {
		.desktop-content {
			display: none;
		}

		.mobile-content {
			display: flex;
			flex-direction: column;
		}

		.tool-bar {
			position: absolute;
			width: 70vw;
			height: 6vh;
			border-radius: 1vw;
			bottom: 0;
			margin: 4vh 15vw;
			border: solid .1vw var(--dark-stroke);
			box-shadow: var(--box-shadow);
			min-width: 30vh;
			z-index: 999 !important;
		}
	}

	.full-height {
		height: 100%;
	}

	.full-width {
		width: 100%;
	}

</style>